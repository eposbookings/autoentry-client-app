APP_PORT=8000
# For VPS testing by IP, use http://your-server-ip for both values below.
REACT_APP_BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

DB_NAME=autoentry_portal
DATABASE_URL=mysql+asyncmy://autoentry_user:change-this-db-password@mysql:3306/autoentry_portal
MYSQL_DATABASE=autoentry_portal
MYSQL_USER=autoentry_user
MYSQL_PASSWORD=change-this-db-password
MYSQL_ROOT_PASSWORD=change-this-root-password

JWT_SECRET=replace-with-a-long-random-secret
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-a-generated-fernet-key
COOKIE_SECURE=false

OPENAI_API_KEY=
OPENAI_INVOICE_CHECK_MODEL=gpt-5.6-luna

# QuickBooks OAuth.
# Local development callback:
# QUICKBOOKS_REDIRECT_URI=http://localhost:8000/api/integrations/quickbooks/callback
# Live callback:
# QUICKBOOKS_REDIRECT_URI=https://eposbookings.net/api/integrations/quickbooks/callback
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_REDIRECT_URI=

ADMIN_EMAIL=admin@eposaccountancy.co.uk
ADMIN_PASSWORD=change-this-password
